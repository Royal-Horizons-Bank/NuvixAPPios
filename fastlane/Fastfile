default_platform(:ios)

platform :ios do
  desc "Build the unsigned .app bundle"
  lane :build_sideload do
    # Auto-detect the workspace and scheme if they vary
    workspace_path = Dir.glob("ios/*.xcworkspace").first
    scheme_name = File.basename(workspace_path, ".xcworkspace") if workspace_path

    build_app(
      workspace: workspace_path, 
      scheme: scheme_name,
      configuration: "Release",
      clean: true,
      skip_package_ipa: true, 
      derived_data_path: "./derived_data",
      xcargs: [
        "CODE_SIGNING_ALLOWED=NO",
        "CODE_SIGNING_REQUIRED=NO",
        "CODE_SIGN_IDENTITY=''",
        "CODE_SIGN_ENTITLEMENTS=''",
        "GCC_OPTIMIZATION_LEVEL=0",
        "ENABLE_USER_SCRIPT_SANDBOXING=NO",
        "ARCHS=arm64",
        "COMPILER_INDEX_STORE_ENABLE=NO"
      ].join(" ")
    )
  end
end