default_platform(:ios)

platform :ios do
  desc "Build the unsigned .app bundle"
  lane :build_sideload do
    build_app(
      workspace: "ios/Nuvixapp.xcworkspace",
      scheme: "NuvixApp",
      configuration: "Release",
      skip_package_ipa: true, 
      xcargs: "CODE_SIGNING_ALLOWED=NO " \
              "CODE_SIGNING_REQUIRED=NO " \
              "CODE_SIGN_IDENTITY='' " \
              "CODE_SIGN_ENTITLEMENTS='' " \
              "GCC_OPTIMIZATION_LEVEL=0 " \
              "SWIFT_VERSION=5.0 " \
              "SWIFT_STRICT_CONCURRENCY=minimal " \
              "OTHER_SWIFT_FLAGS='-suppress-warnings'"
    )
  end
end