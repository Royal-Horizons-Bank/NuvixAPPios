default_platform(:ios)

platform :ios do
  desc "Build the .app bundle for Nuvix+"
  lane :build_app_bundle do
    build_app(
      workspace: "ios/Nuvix.xcworkspace", 
      scheme: "Nuvix",
      configuration: "Release",
      clean: true,
      # This tells Fastlane to skip creating the .ipa file
      skip_package_ipa: true, 
      # Optional: set a custom path so you know exactly where the .app goes
      build_path: "./build",
      derived_data_path: "./derived_data",
      xcargs: "CODE_SIGNING_ALLOWED=NO CODE_SIGNING_REQUIRED=NO CODE_SIGN_IDENTITY='' CODE_SIGN_ENTITLEMENTS='' GCC_OPTIMIZATION_LEVEL=0"
    )
  end
end