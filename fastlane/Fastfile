default_platform(:ios)

platform :ios do
  desc "Build the unsigned .app bundle"
  lane :build_sideload do
    build_app(
      workspace: "ios/Nuvix.xcworkspace",
      scheme: "Nuvix",
      configuration: "Release",
      skip_package_ipa: true,
      clean: true, # Added clean build to clear corrupted derived data
      xcargs: "CODE_SIGNING_ALLOWED=NO " \
              "CODE_SIGNING_REQUIRED=NO " \
              "CODE_SIGN_IDENTITY='' " \
              "CODE_SIGN_ENTITLEMENTS='' " \
              "ARCHS=arm64 " \
              "ONLY_ACTIVE_ARCH=NO " \
              "SWIFT_VERSION=5.0 " \
              "SWIFT_STRICT_CONCURRENCY=minimal " \
              "OTHER_SWIFT_FLAGS='-suppress-warnings -Xfrontend -disable-implicit-concurrency-module-import'"
    )
  end
end