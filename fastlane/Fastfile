default_platform(:ios)

platform :ios do
  desc "Build the unsigned .app bundle for Nuvix+"
  lane :build_sideload do
    build_app(
      workspace: "ios/Nuvix.xcworkspace", 
      scheme: "Nuvix",
      configuration: "Release",
      clean: true,
      skip_package_ipa: true, 
      derived_data_path: "./derived_data",
      xcargs: [
        "CODE_SIGNING_ALLOWED=NO",
        "CODE_SIGNING_REQUIRED=NO",
        "CODE_SIGN_IDENTITY=''",
        "CODE_SIGN_ENTITLEMENTS=''",
        "GCC_OPTIMIZATION_LEVEL=0", # Keep this at 0 for speed
        "ENABLE_USER_SCRIPT_SANDBOXING=NO",
        "ARCHS=arm64",
        # CRITICAL: Prevents timeout by disabling background indexing
        "COMPILER_INDEX_STORE_ENABLE=NO"
      ].join(" ")
    )
  end
end