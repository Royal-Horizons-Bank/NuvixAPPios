default_platform(:ios)

platform :ios do
  desc "Build a signed app for sideloading"
  lane :build_sideload do
    build_app(
      workspace: "ios/Nuvix.xcworkspace", 
      scheme: "Nuvix",
      configuration: "Release",
      clean: true,
      skip_package_ipa: true, 
      xcargs: "CODE_SIGNING_ALLOWED=NO CODE_SIGNING_REQUIRED=NO CODE_SIGN_IDENTITY='' CODE_SIGN_ENTITLEMENTS='' GCC_OPTIMIZATION_LEVEL=0 COMPILER_INDEX_STORE_ENABLE=NO STRIP_INSTALLED_PRODUCT=NO SEARCH_DIRS_SKIP_BUNDLED_FRAMEWORKS=YES"
    )
  end
end