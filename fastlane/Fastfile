default_platform(:ios)

platform :ios do
  desc "Build a signed app for sideloading"
  lane :build_sideload do
    build_app(
      workspace: "ios/Nuvix.xcworkspace", 
      scheme: "Nuvix",
      configuration: "Release",
      clean: true,
      skip_package_ipa: true, 
      # Enhanced xcargs to ignore the "disabling previews" and "script phase" warnings
      xcargs: "CODE_SIGNING_ALLOWED=NO CODE_SIGNING_REQUIRED=NO CODE_SIGN_IDENTITY='' CODE_SIGN_ENTITLEMENTS='' GCC_OPTIMIZATION_LEVEL=0 COMPILER_INDEX_STORE_ENABLE=NO SWIFT_TREAT_WARNINGS_AS_ERRORS=NO PROVISIONING_PROFILE_SPECIFIER='' AD_HOC_CODE_SIGNING_ALLOWED=YES"
    )
  end
end